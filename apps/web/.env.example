# =============================================================================
# O Financeiro Web — Environment Variables
# =============================================================================

# --- API URL ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- PWA environment label ---
# Optional. When set, the manifest name becomes "O Financeiro (<label>)"
# so the home-screen icon is distinguishable from production.
# Use only on staging/preview environments. Leave empty for production.
NEXT_PUBLIC_APP_ENV_LABEL=
