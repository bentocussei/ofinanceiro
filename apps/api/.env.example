# =============================================================================
# O Financeiro API — Environment Variables
# =============================================================================
# Copy to .env and fill in the values for local development.
# For staging/production, configure via Railway env vars.

# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- Database ---
DATABASE_URL=postgresql+asyncpg://ofinanceiro:ofinanceiro@localhost:5432/ofinanceiro

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
JWT_SECRET=dev-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=100
CHAT_RATE_LIMIT_PER_MINUTE=20

# --- Twilio (SMS/OTP) ---
# Leave empty for dev mode (OTPs logged to console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# --- Stripe (Billing) ---
# Leave empty for dev mode (mock checkout)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Cloudflare R2 (File Storage) ---
# Leave empty for dev mode (uploads will fail gracefully)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ofinanceiro-storage
R2_PUBLIC_URL=

# --- Service Token (Cron Jobs) ---
SERVICE_TOKEN=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=O Financeiro <noreply@ofinanceiro.app>

# --- AI ---
# Leave empty for dev mode (MockLLMProvider used)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
