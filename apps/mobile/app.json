{
  "expo": {
    "name": "O Financeiro",
    "slug": "ofinanceiro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ofinanceiro",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.ofinanceiro.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Precisamos de acesso a camara para digitalizar recibos e extrair informacoes automaticamente.",
        "NSFaceIDUsageDescription": "Usa Face ID para proteger o acesso a app.",
        "CFBundleLocalizations": ["pt"],
        "CFBundleDevelopmentRegion": "pt"
      }
    },
    "android": {
      "package": "app.ofinanceiro.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "NOTIFICATIONS",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "VIBRATE"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Precisamos de acesso a camara para digitalizar recibos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#000000"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Usa Face ID para proteger o acesso a app."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "ofinanceiro"
      }
    },
    "owner": "bentocussei",
    "updates": {
      "url": "https://u.expo.dev/ofinanceiro"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
